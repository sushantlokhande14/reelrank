# Copy this file to .env and fill in your values. .env is gitignored and is never
# committed. Set these as host environment variables in production.

# TMDB API key (v3 auth) from https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Optional: Relay LLM gateway base URL + key, for query understanding and the
# short "why we picked this" explanations. Leave blank to disable.
RELAY_BASE_URL=
RELAY_API_KEY=
